---
import Layout from '../layouts/Layout.astro';
---
<Layout title="AI Automation Architect">
  <section class="max-w-5xl mx-auto px-6 py-24 md:py-36">
    <div class="max-w-3xl">
      <h1 class="text-4xl md:text-5xl font-semibold text-dtkt-blue leading-tight mb-6">
        I build AI automation pipelines that replace hours of manual data work.
      </h1>
      <p class="text-xl text-gray-600 mb-10 leading-relaxed">
        Lead lists. Deal alerts. Competitive reports. Delivered automatically, into tools you already use.
      </p>
      <div class="flex flex-wrap items-center gap-4">
        <a href="https://calendly.com/datakit/book-a-call" class="inline-block bg-dtkt-green text-white font-medium px-7 py-3 rounded-[0.6rem] hover:opacity-90 transition-opacity">
          Book a 30-min demo →
        </a>
        <a href="/services" class="text-dtkt-blue font-medium hover:underline">
          See what I offer →
        </a>
      </div>
    </div>
  </section>
</Layout>
