---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Contact" description="Book a 30-minute demo with Jordan Fowler to talk AI automation.">
  <section class="max-w-2xl mx-auto px-6 py-20 text-center">
    <h1 class="text-3xl md:text-4xl font-semibold text-dtkt-blue mb-6">Let's talk.</h1>
    <p class="text-lg text-gray-600 mb-10 leading-relaxed">
      Book a 30-minute demo and show me what you're trying to automate.
      No pitch — just a look at whether it's a good fit.
    </p>

    <a href="https://calendly.com/datakit/book-a-demo" class="inline-block bg-dtkt-green text-white font-medium text-lg px-10 py-4 rounded-[0.6rem] hover:opacity-90 transition-opacity mb-10">
      Book a 30-min demo →
    </a>

    <p class="text-sm text-gray-500">
      Or email: <a href="mailto:jordan@jordanfowler.co" class="text-dtkt-blue hover:underline">jordan@jordanfowler.co</a>
    </p>
  </section>
</Layout>
